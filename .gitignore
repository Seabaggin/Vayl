# ============================================================
# .gitignore — Vayl
# ============================================================

# ── Design/planning docs (specs, plans, mockups, handoffs, audits) ──
# Working artifacts from design sessions — not shipped app content.
# Untracked 2026-07-07: app is ~85% done, most of this won't be
# needed post-launch. Kept on disk, just no longer versioned.
docs/

# ── Script Output Files ──────────────────────────────────────
*OUTPUT
*OUTPUT_FILE

# ── Secrets & Keys ──────────────────────────────────────────
# NEVER commit API keys, tokens, or certificates.
*.xcconfig
.env
*.pem
*.p12
*.mobileprovision
*.cer

# ── Xcode Build Artifacts ───────────────────────────────────
DerivedData/
build/
*.o
*.d
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# ── Swift Package Manager ───────────────────────────────────
.build/
.build-claude/
.swiftpm/
Packages/
Package.resolved

# ── Agent tool scratch (not project source) ──────────────────
.codex/

# ── Xcode User Data ─────────────────────────────────────────
# Per-developer settings — should not be shared.
xcuserdata/
*.xccheckout
*.moved-aside
*.xcuserstate
project.xcworkspace/xcuserdata/
*.xcscmblueprint

# ── SwiftData / SQLite ──────────────────────────────────────
# Local on-device databases containing desire ratings,
# session records, and safe words. Never commit user data.
*.sqlite
*.sqlite-wal
*.sqlite-shm
*.db

# ── macOS ────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Simulator & Device ──────────────────────────────────────
*.app

# ── Crash Logs ──────────────────────────────────────────────
*.crash

# ── SPM Resolved (optional — remove if you want lockfile) ───
# Uncomment the line below if you want to commit Package.resolved
# (recommended for reproducible builds):
# !Package.resolved
Config.swift
.aider*
.worktrees/

# ── Generated / Tooling State ───────────────────────────────
repomix-output.xml
.superpowers/

# ── Scratch / Screen Recordings (never commit to the app repo) ──
*.mov
*.mp4
