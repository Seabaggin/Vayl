{
  "id": "jealousy",
  "title": "Jealousy & What It's Telling You",
  "subtitle": "Information, if you'll read it.",
  "category": "nmSpecific",
  "act": 1,
  "intensity": 5,
  "is_locked": true,
  "required_entitlement": "core",
