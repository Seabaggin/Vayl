      "id": "aln-01",
      "deck_id": "after-last-night",
      "text": "One word for last night.\n\nNot the word you think you should say.\n\nThe one that's actually there.",
      "highlight_words": [
        "One word"
      ],
      "type": "snapshot",
      "intensity": 2,
      "who_starts": "both",
      "is_sensitive": false,
      "can_skip": false,
