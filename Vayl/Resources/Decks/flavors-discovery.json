      "gendered_for": null,
      "sort_order": 2
    },
    {
      "id": "f-03",
      "deck_id": "flavors-discovery",
      "text": "What if you were both at a party where flirting was allowed and expected...\n\nWhat do you picture yourself doing?",
      "highlight_words": [
