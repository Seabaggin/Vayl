      "id": "f-01",
      "deck_id": "flavors-discovery",
      "text": "When you imagine \"more open,\" what single image comes to mind first?\n\nDescribe the picture exactly as it appears.",
      "highlight_words": [
        "single image"
      ],
      "type": "prompt",
      "intensity": 2,
      "who_starts": "partnerA",
      "is_sensitive": false,
      "can_skip": false,
      "register": "flexible",
      "context_beat_type": "banner",
      "context_beat_copy": "Nothing tonight is a commitment. This deck is a fitting room.",
      "back_copy": null,
      "is_gendered_card": false,
      "gendered_for": null,
      "sort_order": 1
    },
    {
      "id": "f-02",
      "deck_id": "flavors-discovery",
      "text": "What draws you toward this at all?\n\nThe honest pull underneath the curiosity.",
